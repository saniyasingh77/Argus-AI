# Copy to .env and fill in real values. NEVER commit the real .env.
# In Docker/Kubernetes these are injected as environment variables / secrets.

# --- Server ---
ARGUS_HOST=0.0.0.0
ARGUS_PORT=5000
ARGUS_DEBUG=false

# Seed demo login (demo@argus.ai/demo123, admin@argus.ai/admin123) + sample
# activity so the dashboard is populated. Great for hosted demos.
ARGUS_SEED_DEMO=true

# --- Storage ---
# Absolute paths inside the container; mount a volume at /data for persistence.
ARGUS_DATA_DIR=/data
ARGUS_DB_PATH=/data/patient.db
# Optional trained model artifact (only needed for CV video analysis)
# ARGUS_MODEL_PATH=/models/activity_model.h5

# --- Email alerts (Gmail SMTP example) ---
ARGUS_SMTP_HOST=smtp.gmail.com
ARGUS_SMTP_PORT=465
ARGUS_EMAIL_SENDER=you@example.com
ARGUS_EMAIL_PASSWORD=your_gmail_app_password
ARGUS_EMAIL_RECIPIENTS=doctor@example.com,nurse@example.com

# --- WhatsApp alerts (Twilio) ---
ARGUS_TWILIO_SID=your_twilio_account_sid
ARGUS_TWILIO_TOKEN=your_twilio_auth_token
ARGUS_WHATSAPP_FROM=whatsapp:+14155238886
ARGUS_WHATSAPP_TO=whatsapp:+910000000000
